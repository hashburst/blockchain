# Fase di build
FROM golang:1.22-alpine AS builder

WORKDIR /app
COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux go build -o blockchain .

# Fase finale
FROM alpine:latest

WORKDIR /app

# Installazione dipendenze minime
RUN apk add --no-cache libc6-compat

# Copia solo i file necessari
COPY --from=builder /app/blockchain .
COPY --from=builder /app/config ./config

# Verifica senza eseguire
RUN chmod +x blockchain && \
    ls -la blockchain && \
    file blockchain 2>/dev/null || true

EXPOSE 8080

# Comando di avvio
CMD ["./blockchain"]
